<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="AppTheme" parent="AppTheme.Override">
        <!-- Dark theme status and navigation bars -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
        
        <!-- Material Design 3 colors for dark theme (compatible with API 24+) -->
        <item name="colorPrimary">#90CAF9</item>
        <item name="colorOnPrimary">#0D47A1</item>
        <item name="colorPrimaryContainer">#1565C0</item>
        <item name="colorOnPrimaryContainer">#E3F2FD</item>
        
        <item name="colorSecondary">#A5D6A7</item>
        <item name="colorOnSecondary">#1B5E20</item>
        <item name="colorSecondaryContainer">#2E7D32</item>
        <item name="colorOnSecondaryContainer">#E8F5E8</item>
        
        <item name="colorTertiary">#D0BCFF</item>
        <item name="colorOnTertiary">#381E72</item>
        <item name="colorTertiaryContainer">#4F378B</item>
        <item name="colorOnTertiaryContainer">#EADDFF</item>
        
        <!-- Surface colors for dark theme -->
        <item name="colorSurface">#10131C</item>
        <item name="colorOnSurface">#E6E1E5</item>
        <item name="colorSurfaceVariant">#49454F</item>
        <item name="colorOnSurfaceVariant">#CAC4D0</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">#10131C</item>
        <item name="colorOnBackground">#E6E1E5</item>
        
        <!-- Enhanced edge-to-edge support for dark theme -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="api_level_35">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="api_level_35">false</item>
    </style>
</resources>